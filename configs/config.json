{
    "audio_processing": {
        "sample_rate": 22050,
        "min_duration": 1.0,
        "max_duration": 20.0,
        "target_db": -20,
        "trim_silence": true,
        "vad_silence_threshold": -40,
        "normalize_audio": true,
        "min_snr": 10,
        "noise_reduce": true,
        "max_silence_gap": 0.3,
        "use_advanced_trimming": true,
        "hop_length": 256,
        "win_length": 1024,
        "n_fft": 1024,
        "n_mels": 80,
        "fmin": 0,
        "fmax": 8000,
        "resolution_bits": 16,
        "min_amplitude": 0.001,
        "max_peak": 0.95,
        "target_lufs": -16.0,
        "use_webrtc_vad": true,
        "loudness_normalization": true
    },

    "training": {
        "batch_size": 16,
        "learning_rate": 0.0002,
        "num_epochs": 1000,
        "total_steps": 100000,
        "save_every": 1000,
        "eval_every": 500,
        "warmup_steps": 4000,
        "gradient_clip": 1.0,
        "fp16_run": false,
        "grad_accum_steps": 1,
        "log_every": 100,
        "multi_speaker": true,
        "use_mel_posterior_encoder": true,
        "use_sdp": true,
        "loss_weights": {
            "kl": 1.0,
            "reconstruction": 1.0,
            "mel": 45.0,
            "feature_matching": 2.0,
            "discriminator": 1.0,
            "generator": 1.0,
            "duration": 1.0
        }
    },
    "paths": {
        "train_file": "filelists/nepali_train_filelist.txt",
        "valid_file": "filelists/nepali_val_filelist.txt",
        "checkpoint_dir": "checkpoints",
        "log_dir": "logs"
    },

    "vits": {
        "model_type": "multi_speaker",
        "use_speaker_embedding": true,
        "speaker_embedding_dim": 256,
        "text_encoder": {
            "hidden_channels": 192,
            "filter_channels": 768,
            "n_heads": 2,
            "n_layers": 6,
            "kernel_size": 3,
            "p_dropout": 0.1
        },
        "posterior_encoder": {
            "hidden_channels": 192,
            "out_channels": 192,
            "filter_channels": 768,
            "n_heads": 2,
            "n_layers": 16,
            "kernel_size": 5,
            "p_dropout": 0.1
        },
        "flow": {
            "hidden_channels": 192,
            "kernel_size": 5,
            "dilation_rate": 1,
            "n_blocks": 4,
            "n_layers": 4,
            "p_dropout": 0.05
        },
        "decoder": {
            "hidden_channels": 512,
            "kernel_size": 7,
            "dilation_rate": 1,
            "n_layers": 3,
            "upsample_rates": [
                8,
                8,
                2,
                2
            ],
            "upsample_kernel_sizes": [
                16,
                16,
                4,
                4
            ],
            "upsample_initial_channel": 512,
            "resblock_kernel_sizes": [
                3,
                7,
                11
            ],
            "resblock_dilation_sizes": [
                [
                    1,
                    3,
                    5
                ],
                [
                    1,
                    3,
                    5
                ],
                [
                    1,
                    3,
                    5
                ]
            ]
        },
        "duration_predictor": {
            "hidden_channels": 192,
            "kernel_size": 3,
            "p_dropout": 0.5,
            "n_flows": 4,
            "gin_channels": 256
        }
    },
    "discriminator": {
        "multi_period": {
            "periods": [
                2,
                3,
                5,
                7,
                11
            ],
            "kernel_size": 5,
            "stride": 3,
            "use_spectral_norm": false
        },
        "multi_scale": {
            "scales": 3,
            "downsample_factor": 4,
            "kernel_sizes": [
                15,
                41,
                5,
                3
            ],
            "use_spectral_norm": false
        }
    },
    "inference": {
        "noise_scale": 0.667,
        "noise_scale_w": 0.8,
        "length_scale": 1.0,
        "max_len": 1000
    }
}